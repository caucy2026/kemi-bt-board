<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_glass_bg"
    android:padding="16dp"
    android:layout_gravity="center">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Windows U+ 助手安装说明"
        android:textColor="#00ADB5"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E3A4E"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvWinGuideContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="正在启动安装服务..."
        android:textColor="#EEEEEE"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.15" />

    <Button
        android:id="@+id/btnWinGuideClose"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/button_mac_helper"
        android:text="我明白了"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

</LinearLayout>
