<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_glass_bg"
    android:padding="16dp"
    android:layout_gravity="center">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mac 电脑设置 Unicode 输入法"
        android:textColor="#00ADB5"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E3A4E"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. 点击 Mac 左上角苹果图标  -> 系统设置\n\n2. 找到【键盘】-> 输入法 -> 点击【编辑...】\n\n3. 点击左下角【+】号，在搜索框中输入：Unicode 或 十六进制\n\n4. 选择【Unicode 十六进制输入】并点击【添加】\n\n5. 重要提示：打字前，点击 Mac 屏幕右上角输入法图标，切换至【Unicode 十六进制输入】(显示为 U+)"
        android:textColor="#EEEEEE"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.15" />

    <Button
        android:id="@+id/btnGuideClose"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/button_mac_helper"
        android:text="我明白了"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

</LinearLayout>
