<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state: pressed down -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/enter_active" />
                    <corners android:radius="12dp" />
                    <stroke android:width="2dp" android:color="#14b8a6" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Normal state: raised 3D look with bottom shadow -->
    <item>
        <layer-list>
            <!-- Bottom Shadow Layer -->
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#020617" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <!-- Raised Surface Layer -->
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/enter_inactive" />
                    <corners android:radius="12dp" />
                    <stroke android:width="1dp" android:color="#3314b8a6" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
