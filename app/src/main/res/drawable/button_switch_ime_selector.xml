<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#F59E0B" />
                    <corners android:radius="12dp" />
                    <stroke android:width="1.5dp" android:color="#FBBF24" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Normal state: matching key_modifier_selector 3D structure with amber/yellow theme -->
    <item>
        <layer-list>
            <!-- Bottom Shadow Layer -->
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#020617" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <!-- Raised Surface Layer -->
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#B45309" />
                    <corners android:radius="12dp" />
                    <stroke android:width="1.5dp" android:color="#F59E0B" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
