<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#14B8A6" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.5dp" android:color="#2DD4BF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Normal state -->
    <item>
        <layer-list>
            <!-- Bottom Shadow Layer -->
            <item android:top="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#0F4C45" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <!-- Top Key Cap Layer -->
            <item android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#0D9488"
                        android:endColor="#0F766E"
                        android:angle="270" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.5dp" android:color="#14B8A6" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
